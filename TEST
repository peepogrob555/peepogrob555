cat > /usr/local/bin/ssh-panel/adduser.sh <<'PANEL_ADDUSER_SH'
#!/bin/bash
# adduser.sh <username> <password> <expiry_days>
# รันด้วย root ผ่าน sudo (จำกัดไว้ใน /etc/sudoers.d/ssh-panel เท่านั้น)
set -euo pipefail

USERNAME="${1:-}"
PASSWORD="${2:-}"
DAYS="${3:-}"

# ตรวจซ้ำอีกชั้นในฝั่ง shell แม้ Node.js จะ validate มาแล้ว (defense in depth)
if ! [[ "$USERNAME" =~ ^[a-z][a-z0-9_-]{2,31}$ ]]; then
  echo "Invalid username" >&2
  exit 1
fi
if [[ -z "$PASSWORD" || "$PASSWORD" =~ [[:space:]] ]]; then
  echo "Invalid password" >&2
  exit 1
fi
if ! [[ "$DAYS" =~ ^[0-9]+$ ]] || [[ "$DAYS" -lt 1 || "$DAYS" -gt 3650 ]]; then
  echo "Invalid expiry days" >&2
  exit 1
fi
if id "$USERNAME" &>/dev/null; then
  echo "User already exists" >&2
  exit 1
fi

EXPIRE_DATE=$(date -d "+${DAYS} days" +%Y-%m-%d)

# shell เป็น /usr/sbin/nologin: กันไม่ให้ login แบบ interactive shell ได้
# แต่ SSH port-forward / tunnel ยังใช้งานได้ปกติ เพราะไม่ต้องพึ่ง shell
useradd -m -s /usr/sbin/nologin -e "$EXPIRE_DATE" "$USERNAME"
echo "${USERNAME}:${PASSWORD}" | chpasswd

echo "Created user ${USERNAME}, expires ${EXPIRE_DATE}"
PANEL_ADDUSER_SH

