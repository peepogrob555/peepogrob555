cat > /usr/local/bin/ssh-panel/adduser.sh <<'EOF'
#!/bin/bash
set -euo pipefail
USERNAME="${1:-}"; PASSWORD="${2:-}"
[[ "$USERNAME" =~ ^[a-z][a-z0-9_-]{2,31}$ ]] || { echo "Invalid username" >&2; exit 1; }
[[ -n "$PASSWORD" && ! "$PASSWORD" =~ [[:space:]] ]] || { echo "Invalid password" >&2; exit 1; }
id "$USERNAME" &>/dev/null && { echo "User exists" >&2; exit 1; }
useradd -m -s /usr/sbin/nologin "$USERNAME"
echo "${USERNAME}:${PASSWORD}" | chpasswd
echo "Created ${USERNAME} (ไม่จำกัดวันใช้งาน)"
EOF

cat > /usr/local/bin/ssh-panel/deluser.sh <<'EOF'
#!/bin/bash
set -euo pipefail
USERNAME="${1:-}"
[[ "$USERNAME" =~ ^[a-z][a-z0-9_-]{2,31}$ ]] || { echo "Invalid username" >&2; exit 1; }
id "$USERNAME" &>/dev/null || { echo "No such user" >&2; exit 1; }
[[ "$USERNAME" != "root" && "$USERNAME" != "panelsvc" ]] || { echo "Protected" >&2; exit 1; }
pkill -KILL -u "$USERNAME" 2>/dev/null || true
userdel -r "$USERNAME"
echo "Deleted ${USERNAME}"
EOF

cat > /usr/local/bin/ssh-panel/listusers.sh <<'EOF'
#!/bin/bash
set -euo pipefail
awk -F: '$3>=1000 && $3<60000 && $1!="panelsvc" && $1!="nobody"{print $1}' /etc/passwd | while read -r u; do
  echo "${u} | ไม่จำกัดวันใช้งาน"
done
EOF

cat > /usr/local/bin/ssh-panel/onlineusers.sh <<'EOF'
#!/bin/bash
set -euo pipefail
echo "--- who ---"; who || true
echo "--- established (22/80/443) ---"
ss -tnp state established '( dport = :22 or dport = :80 or dport = :443 or sport = :22 or sport = :80 or sport = :443 )' 2>/dev/null || true
EOF

chown root:root /usr/local/bin/ssh-panel/*.sh
chmod 700 /usr/local/bin/ssh-panel/*.sh
id -u panelsvc &>/dev/null || useradd -r -s /usr/sbin/nologin panelsvc

cat > /etc/sudoers.d/ssh-panel <<EOF
panelsvc ALL=(root) NOPASSWD: /usr/local/bin/ssh-panel/adduser.sh, /usr/local/bin/ssh-panel/deluser.sh, /usr/local/bin/ssh-panel/listusers.sh, /usr/local/bin/ssh-panel/onlineusers.sh
EOF
chmod 440 /etc/sudoers.d/ssh-panel
visudo -c

cd "$PANEL_DIR"
npm install --omit=dev
ADMIN_HASH=$(node -e "require('bcryptjs').hash(process.argv[1],10).then(h=>console.log(h))" "$PANEL_ADMIN_PASS")
SESSION_SECRET=$(openssl rand -hex 32)

cat > "$PANEL_DIR/.env" <<EOF
