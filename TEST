#!/bin/bash
###############################################################################
# install.sh — SSH Tunnel Server Setup (Ubuntu Server 22.04)
#
# ติดตั้ง: OpenSSH, Dropbear, badvpn-udpgw, Nginx (WSS reverse proxy),
#          Certbot/Let's Encrypt, UFW, Fail2Ban, sysctl/BBR tuning
#
# วิธีใช้:
#   sudo bash install.sh
#
# สคริปต์นี้ "ทำเอง" ทุกขั้นตอนแบบ manual (ไม่พึ่ง auto-script สำเร็จรูปจากที่อื่น
# ไม่ใช้ Docker ไม่ใช้ Panel สำเร็จรูป) แต่รวมเป็นไฟล์เดียวเพื่อความสะดวกในการรัน
###############################################################################
set -euo pipefail
trap 'echo "[ERROR] เกิดข้อผิดพลาดที่บรรทัด $LINENO — สคริปต์หยุดทำงาน" >&2' ERR

if [[ $EUID -ne 0 ]]; then
  echo "กรุณารันด้วย sudo หรือ root: sudo bash install.sh" >&2
  exit 1
fi

log()  { echo -e "\n\033[1;32m==> $*\033[0m"; }
warn() { echo -e "\033[1;33m[!] $*\033[0m"; }

###############################################################################
# 0. รับค่าตั้งต้นจากผู้ใช้ (ค่าเฉพาะเครื่อง ไม่ควรฝังตายตัวในสคริปต์)
###############################################################################
log "0. กรอกค่าตั้งต้น"

read -rp "Hostname ที่ต้องการตั้ง (เช่น vps-tunnel): " NEW_HOSTNAME
read -rp "Timezone (เช่น Asia/Bangkok): " TZ_NAME
TZ_NAME=${TZ_NAME:-Asia/Bangkok}
read -rp "ชื่อ user ระบบใหม่ (สำหรับ sudo, ไม่ใช่ root): " SYS_USER
read -rsp "รหัสผ่านของ user นี้: " SYS_USER_PASS; echo
read -rp "โดเมนที่ชี้มาที่ VPS นี้แล้ว (เช่น tunnel.example.com): " DOMAIN
read -rp "อีเมลสำหรับ Let's Encrypt (แจ้งเตือนก่อน cert หมดอายุ): " LE_EMAIL
read -rp "Username สำหรับเข้าเว็บพาแนลจัดการ user (ไม่ใช่ user ระบบ): " PANEL_ADMIN_USER
read -rsp "Password สำหรับเว็บพาแนล: " PANEL_ADMIN_PASS; echo

SSH_PORT=22
DROPBEAR_PORT_PUBLIC=80
DROPBEAR_PORT_INTERNAL=109
NGINX_SSL_PORT=443
UDPGW_PORT=7300
PANEL_PORT=3000

###############################################################################
# 1. เตรียมระบบพื้นฐาน
###############################################################################
log "1.1 apt update / upgrade — อัปเดต package list และแพตช์ความปลอดภัย"
export DEBIAN_FRONTEND=noninteractive
apt update -y
apt upgrade -y
apt install -y curl wget git build-essential cmake ufw fail2ban unzip \
  software-properties-common ca-certificates gnupg lsb-release chrony

log "1.2 ตั้ง Timezone เป็น ${TZ_NAME} — ให้ log/cert หมดอายุตรงเวลาจริง"
timedatectl set-timezone "$TZ_NAME"

log "1.3 ตั้ง Hostname เป็น ${NEW_HOSTNAME}"
hostnamectl set-hostname "$NEW_HOSTNAME"
sed -i "s/^127.0.1.1.*/127.0.1.1\t${NEW_HOSTNAME}/" /etc/hosts || \
  echo "127.0.1.1 ${NEW_HOSTNAME}" >> /etc/hosts

log "1.4 สร้าง user ใหม่ (${SYS_USER}) เพื่อเลิกใช้ root ทำงานประจำวัน"
if id "$SYS_USER" &>/dev/null; then
  warn "user ${SYS_USER} มีอยู่แล้ว ข้ามการสร้าง"
else
  adduser --gecos "" --disabled-password "$SYS_USER"
  echo "${SYS_USER}:${SYS_USER_PASS}" | chpasswd
  usermod -aG sudo "$SYS_USER"
fi

log "1.5 เตรียมโฟลเดอร์ .ssh ให้ user ใหม่ (รองรับ SSH key ในอนาคต)"
install -d -m 700 -o "$SYS_USER" -g "$SYS_USER" "/home/${SYS_USER}/.ssh"
touch "/home/${SYS_USER}/.ssh/authorized_keys"
chown "$SYS_USER:$SYS_USER" "/home/${SYS_USER}/.ssh/authorized_keys"
chmod 600 "/home/${SYS_USER}/.ssh/authorized_keys"
warn "ถ้าจะใช้ SSH Key ให้นำ public key ไปวางใน /home/${SYS_USER}/.ssh/authorized_keys เอง"

###############################################################################
# 2. Firewall (UFW)
###############################################################################
log "2. ตั้งค่า UFW — เปิดเฉพาะพอร์ตที่ใช้งานจริงเท่านั้น"
ufw default deny incoming
ufw default allow outgoing
ufw allow "${SSH_PORT}/tcp"        comment 'OpenSSH'
ufw allow "${DROPBEAR_PORT_PUBLIC}/tcp" comment 'Dropbear raw/payload'
ufw allow "${NGINX_SSL_PORT}/tcp"  comment 'Nginx SSL/WSS'
ufw allow "${UDPGW_PORT}/udp"      comment 'badvpn-udpgw'
# หมายเหตุ: ไม่เปิด UDP 1-65535 — udpgw ใช้พอร์ตเดียว (7300) รับ-ส่งข้อมูล
# แล้วมัน relay ไปปลายทางจริงเอง ไม่จำเป็นต้องเปิดพอร์ตอื่นเพิ่มเลย
ufw --force enable
ufw status verbose

###############################################################################
# 3. OpenSSH
###############################################################################
log "3. ตั้งค่า OpenSSH (${SSH_PORT})"
apt install -y openssh-server
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak.$(date +%s)

sed -i \
  -e "s/^#\?Port .*/Port ${SSH_PORT}/" \
  -e "s/^#\?PermitRootLogin .*/PermitRootLogin no/" \
  -e "s/^#\?PasswordAuthentication .*/PasswordAuthentication yes/" \
  -e "s/^#\?MaxAuthTries .*/MaxAuthTries 3/" \
  -e "s/^#\?ClientAliveInterval .*/ClientAliveInterval 60/" \
  -e "s/^#\?ClientAliveCountMax .*/ClientAliveCountMax 3/" \
  -e "s/^#\?AllowTcpForwarding .*/AllowTcpForwarding yes/" \
  -e "s/^#\?X11Forwarding .*/X11Forwarding no/" \
  /etc/ssh/sshd_config
# เพิ่มค่าที่อาจไม่มีอยู่เดิม
grep -q "^MaxAuthTries" /etc/ssh/sshd_config || echo "MaxAuthTries 3" >> /etc/ssh/sshd_config
grep -q "^ClientAliveInterval" /etc/ssh/sshd_config || echo "ClientAliveInterval 60" >> /etc/ssh/sshd_config
grep -q "^ClientAliveCountMax" /etc/ssh/sshd_config || echo "ClientAliveCountMax 3" >> /etc/ssh/sshd_config
grep -q "^AllowTcpForwarding" /etc/ssh/sshd_config || echo "AllowTcpForwarding yes" >> /etc/ssh/sshd_config

sshd -t   # ทดสอบ syntax ก่อน restart จริง ป้องกันล็อกตัวเองออก
systemctl restart ssh
systemctl enable ssh
systemctl status ssh --no-pager -l | head -5

###############################################################################
# 4. Dropbear
###############################################################################
log "4. ติดตั้ง Dropbear (พอร์ตสาธารณะ ${DROPBEAR_PORT_PUBLIC}, internal ${DROPBEAR_PORT_INTERNAL})"
apt install -y dropbear-bin
mkdir -p /etc/dropbear
if [[ ! -f /etc/dropbear/dropbear_ecdsa_host_key ]]; then
  dropbearkey -t ecdsa -f /etc/dropbear/dropbear_ecdsa_host_key
fi
if [[ ! -f /etc/dropbear/dropbear_rsa_host_key ]]; then
  dropbearkey -t rsa -s 2048 -f /etc/dropbear/dropbear_rsa_host_key
fi

# ปิด dropbear ที่มากับ apt (ใช้ systemd service ของเราเองแทน เพื่อคุมพอร์ตได้ 2 ตัว)
systemctl disable --now dropbear 2>/dev/null || true

cat > /etc/systemd/system/dropbear.service <<EOF
[Unit]
Description=Dropbear SSH server (public ${DROPBEAR_PORT_PUBLIC} + internal ${DROPBEAR_PORT_INTERNAL})
After=network.target

[Service]
ExecStart=/usr/sbin/dropbear -F -E \\
  -p ${DROPBEAR_PORT_PUBLIC} \\
  -p 127.0.0.1:${DROPBEAR_PORT_INTERNAL} \\
  -r /etc/dropbear/dropbear_ecdsa_host_key \\
  -r /etc/dropbear/dropbear_rsa_host_key
Restart=always
RestartSec=3
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable --now dropbear
systemctl status dropbear --no-pager -l | head -5

###############################################################################
# 5. badvpn-udpgw (compile จาก source เพราะไม่มีใน apt ของ 22.04 แล้ว)
###############################################################################
log "5. คอมไพล์และติดตั้ง badvpn-udpgw"
if [[ ! -f /usr/local/bin/badvpn-udpgw ]]; then
  rm -rf /usr/local/src/badvpn
  git clone --depth 1 https://github.com/ambrop72/badvpn.git /usr/local/src/badvpn
  mkdir -p /usr/local/src/badvpn/build
  cd /usr/local/src/badvpn/build
  cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1
  make -j"$(nproc)"
  cp udpgw/badvpn-udpgw /usr/local/bin/badvpn-udpgw
  cd -
else
  warn "badvpn-udpgw มีอยู่แล้ว ข้ามการคอมไพล์"
fi

cat > /etc/systemd/system/badvpn-udpgw.service <<EOF
[Unit]
Description=BadVPN UDP Gateway
After=network.target

[Service]
ExecStart=/usr/local/bin/badvpn-udpgw \\
  --listen-addr 0.0.0.0:${UDPGW_PORT} \\
  --max-clients 1000 \\
  --max-connections-for-client 10
Restart=always
RestartSec=5
User=nobody
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable --now badvpn-udpgw
systemctl status badvpn-udpgw --no-pager -l | head -5

###############################################################################
# 6+7+8. Nginx + SSL (Certbot) + WebSocket reverse proxy
###############################################################################
log "6. ติดตั้ง Nginx"
apt install -y nginx

# ปิด default site กัน conflict
rm -f /etc/nginx/sites-enabled/default

log "7. ขอ SSL certificate ด้วย Certbot (standalone ชั่วคราว เพราะ nginx ยังไม่ฟัง 80/443)"
apt install -y certbot python3-certbot-nginx
systemctl stop nginx 2>/dev/null || true
certbot certonly --standalone --non-interactive --agree-tos \
  -m "$LE_EMAIL" -d "$DOMAIN" --preferred-challenges http

log "7.1 ตั้ง renewal hook: หยุด Dropbear พอร์ต 80 ชั่วคราวตอน renew (กันชนพอร์ต)"
mkdir -p /etc/letsencrypt/renewal-hooks/pre /etc/letsencrypt/renewal-hooks/post
cat > /etc/letsencrypt/renewal-hooks/pre/stop-services.sh <<'EOF'
#!/bin/bash
systemctl stop dropbear nginx
EOF
cat > /etc/letsencrypt/renewal-hooks/post/start-services.sh <<'EOF'
#!/bin/bash
systemctl start dropbear nginx
EOF
chmod +x /etc/letsencrypt/renewal-hooks/pre/stop-services.sh
chmod +x /etc/letsencrypt/renewal-hooks/post/start-services.sh
systemctl enable --now certbot.timer

log "8. เขียนไฟล์ Nginx config พร้อม WebSocket upgrade headers"
cat > /etc/nginx/sites-available/ssh-tunnel.conf <<EOF
# map สำหรับ WebSocket Upgrade header:
# ถ้า client ส่ง "Upgrade: websocket" ให้ \$connection_upgrade = "upgrade"
# ถ้าไม่ส่ง (HTTP ปกติ) ให้ \$connection_upgrade = "close"
map \$http_upgrade \$connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen ${NGINX_SSL_PORT} ssl;
    listen [::]:${NGINX_SSL_PORT} ssl;
    server_name ${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # --- WebSocket -> OpenSSH (พอร์ต 22) ---
    location /ssh-ws {
        proxy_pass http://127.0.0.1:${SSH_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;          # ส่งต่อคำขอ upgrade เป็น websocket
        proxy_set_header Connection \$connection_upgrade;  # บอกให้ต่อ connection ค้างไว้ (ไม่ปิดหลัง response)
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_read_timeout 3600s;   # กัน connection ถูกตัดระหว่าง idle
        proxy_send_timeout 3600s;
    }

    # --- WebSocket -> Dropbear (internal พอร์ต 109) ---
    location /dropbear-ws {
        proxy_pass http://127.0.0.1:${DROPBEAR_PORT_INTERNAL};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # --- เว็บพาแนลจัดการ user (อยู่หลัง SSL, ไม่เปิดพอร์ตตรง) ---
    location /panel/ {
        proxy_pass http://127.0.0.1:${PANEL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        return 444;   # ปิดเส้นทางอื่นทั้งหมดที่ไม่รู้จัก (ลด fingerprint / กัน scanner)
    }
}
EOF

ln -sf /etc/nginx/sites-available/ssh-tunnel.conf /etc/nginx/sites-enabled/ssh-tunnel.conf
nginx -t
systemctl enable --now nginx
systemctl restart nginx

###############################################################################
# 10. Fail2Ban
###############################################################################
log "10. ตั้งค่า Fail2Ban ป้องกัน brute force"
cat > /etc/fail2ban/jail.local <<EOF
[sshd]
enabled  = true
port     = ${SSH_PORT}
filter   = sshd
logpath  = /var/log/auth.log
maxretry = 4
findtime = 300
bantime  = 3600

[nginx-http-auth]
enabled  = true
port     = http,https
logpath  = /var/log/nginx/error.log
EOF
systemctl enable --now fail2ban
systemctl restart fail2ban

###############################################################################
# 11. Web Panel (Node.js) — user management
###############################################################################
log "11. ติดตั้ง Node.js + เว็บพาแนลจัดการ user"
if ! command -v node &>/dev/null; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  apt install -y nodejs
fi

PANEL_DIR=/opt/ssh-panel

# เขียนไฟล์ทั้งหมดของพาแนลลงดิสก์ตรงนี้ (สคริปต์นี้เป็นไฟล์เดียว จบในตัว
# ไม่ต้องพึ่งโฟลเดอร์ panel/ ข้างเคียง — รันผ่าน curl | bash ได้เลย)
mkdir -p /opt/ssh-panel/views /usr/local/bin/ssh-panel

cat > /opt/ssh-panel/package.json <<'PANEL_PACKAGE_JSON'
{
  "name": "ssh-tunnel-panel",
  "version": "1.0.0",
  "description": "Web panel for managing SSH tunnel user accounts",
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0"
  }
}
PANEL_PACKAGE_JSON

cat > /opt/ssh-panel/server.js <<'PANEL_SERVER_JS'
// server.js — SSH Tunnel User Management Panel
//
// สถาปัตยกรรมความปลอดภัย:
//  - Panel รันด้วย user จำกัดสิทธิ์ (panelsvc) ไม่ใช่ root
//  - เรียกคำสั่งระบบผ่าน execFile (ไม่ผ่าน shell) + array args เท่านั้น -> กัน command injection
//  - sudo อนุญาตให้รันได้แค่ script ที่กำหนดไว้ล่วงหน้าใน /etc/sudoers.d/ssh-panel เท่านั้น
//  - ทุก input (username / password / days) ผ่าน whitelist regex ก่อนส่งไป shell script เสมอ
//  - ฟังเฉพาะ 127.0.0.1 -> เข้าถึงได้ผ่าน Nginx (SSL) เท่านั้น ไม่เปิดสู่อินเทอร์เน็ตตรง ๆ

require('dotenv').config();
const express = require('express');
const session = require('express-session');
const rateLimit = require('express-rate-limit');
const bcrypt = require('bcryptjs');
const { execFile } = require('child_process');
const path = require('path');

const app = express();
const PORT = process.env.PANEL_PORT || 3000;
const ADMIN_USER = process.env.ADMIN_USER;
const ADMIN_PASS_HASH = process.env.ADMIN_PASS_HASH;
const SESSION_SECRET = process.env.SESSION_SECRET;

if (!ADMIN_USER || !ADMIN_PASS_HASH || !SESSION_SECRET) {
  console.error('ขาด ADMIN_USER / ADMIN_PASS_HASH / SESSION_SECRET ใน .env — รัน install.sh ให้เสร็จก่อน');
  process.exit(1);
}

const SCRIPTS = {
  add: '/usr/local/bin/ssh-panel/adduser.sh',
  del: '/usr/local/bin/ssh-panel/deluser.sh',
  list: '/usr/local/bin/ssh-panel/listusers.sh',
  online: '/usr/local/bin/ssh-panel/onlineusers.sh',
};

app.set('trust proxy', 1); // อยู่หลัง Nginx reverse proxy
app.use(express.json());
app.use(express.urlencoded({ extended: false }));
app.use(express.static(path.join(__dirname, 'public')));

app.use(session({
  secret: SESSION_SECRET,
  resave: false,
  saveUninitialized: false,
  cookie: {
    httpOnly: true,
    secure: true,       // ต้องเข้าผ่าน https (Nginx SSL) เท่านั้น
    sameSite: 'strict',
    maxAge: 1000 * 60 * 60 * 4, // 4 ชั่วโมง
  },
}));

const loginLimiter = rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 5,
  standardHeaders: true,
  legacyHeaders: false,
  message: { error: 'ลองล็อกอินผิดหลายครั้งเกินไป กรุณารอ 15 นาที' },
});

function requireAuth(req, res, next) {
  if (req.session && req.session.authed) return next();
  return res.status(401).json({ error: 'Unauthorized' });
}

// --- Whitelist validators: ทุก input ต้องผ่านตรงนี้ก่อนแตะ shell เสมอ ---
const usernameRe = /^[a-z][a-z0-9_-]{2,31}$/;
function validUsername(u) { return typeof u === 'string' && usernameRe.test(u); }
function validPassword(p) { return typeof p === 'string' && p.length >= 6 && p.length <= 128 && !/\s/.test(p); }
function validDays(d) {
  const n = Number(d);
  return Number.isInteger(n) && n > 0 && n <= 3650;
}

function runScript(scriptPath, args, res) {
  execFile('sudo', [scriptPath, ...args], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ ok: true, message: stdout.trim() });
  });
}

app.get('/', (req, res) => {
  const file = req.session && req.session.authed ? 'dashboard.html' : 'login.html';
  res.sendFile(path.join(__dirname, 'views', file));
});

app.post('/api/login', loginLimiter, async (req, res) => {
  const { username, password } = req.body || {};
  if (typeof username !== 'string' || typeof password !== 'string') {
    return res.status(400).json({ error: 'ข้อมูลไม่ถูกต้อง' });
  }
  if (username !== ADMIN_USER) return res.status(401).json({ error: 'Username หรือ Password ไม่ถูกต้อง' });
  const ok = await bcrypt.compare(password, ADMIN_PASS_HASH);
  if (!ok) return res.status(401).json({ error: 'Username หรือ Password ไม่ถูกต้อง' });
  req.session.regenerate((err) => {
    if (err) return res.status(500).json({ error: 'เกิดข้อผิดพลาด' });
    req.session.authed = true;
    res.json({ ok: true });
  });
});

app.post('/api/logout', (req, res) => {
  req.session.destroy(() => res.json({ ok: true }));
});

app.get('/api/users', requireAuth, (req, res) => {
  execFile('sudo', [SCRIPTS.list], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ users: stdout.trim().split('\n').filter(Boolean) });
  });
});

app.get('/api/online', requireAuth, (req, res) => {
  execFile('sudo', [SCRIPTS.online], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ online: stdout.trim() });
  });
});

app.post('/api/users', requireAuth, (req, res) => {
  const { username, password, days } = req.body || {};
  if (!validUsername(username)) {
    return res.status(400).json({ error: 'Username ไม่ถูกต้อง (a-z, 0-9, _- เท่านั้น, 3-32 ตัวอักษร, ขึ้นต้นด้วยตัวอักษร)' });
  }
  if (!validPassword(password)) {
    return res.status(400).json({ error: 'Password ไม่ถูกต้อง (6-128 ตัวอักษร ห้ามมีช่องว่าง)' });
  }
  if (!validDays(days)) {
