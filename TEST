cat > /usr/local/bin/apply-cake.sh <<EOF
#!/bin/bash
# apply-cake.sh — แนบ CAKE เข้ากับ default-route interface ทุกครั้งที่บูต
set -euo pipefail
IFACE=\$(ip -4 route show default | awk '{for(i=1;i<=NF;i++) if (\$i=="dev") print \$(i+1)}' | head -1)
if [[ -z "\$IFACE" ]]; then
  echo "ไม่พบ default route interface" >&2
  exit 1
fi
modprobe sch_cake 2>/dev/null || true
# dual-dsthost: แยก fair-queue ตาม destination host -> user คนเดียวแย่ง bandwidth คนอื่นไม่ได้
# rtt 50ms: บอก CAKE ให้คำนวณ target/interval ตาม RTT จริงของ mobile client (แม่นกว่าค่า default 100ms)
tc qdisc replace dev "\$IFACE" root cake bandwidth ${CAKE_MBIT}mbit rtt 50ms dual-dsthost
echo "Applied CAKE on \$IFACE: bandwidth=${CAKE_MBIT}mbit rtt=50ms dual-dsthost"
EOF
chmod +x /usr/local/bin/apply-cake.sh

