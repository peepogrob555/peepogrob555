modprobe sch_cake 2>/dev/null || true
echo "sch_cake" > /etc/modules-load.d/sch_cake.conf
cat > /usr/local/bin/apply-cake.sh <<EOF
#!/bin/bash
set -euo pipefail
IFACE=\$(ip -4 route show default | awk '{for(i=1;i<=NF;i++) if (\$i=="dev") print \$(i+1)}' | head -1)
modprobe sch_cake 2>/dev/null || true
tc qdisc replace dev "\$IFACE" root cake bandwidth ${CAKE_MBIT}mbit rtt 50ms dual-dsthost
EOF
chmod +x /usr/local/bin/apply-cake.sh
cat > /etc/systemd/system/cake-shaper.service <<'EOF'
[Unit]
Description=CAKE shaping
After=network-online.target
Wants=network-online.target
[Service]
Type=oneshot
ExecStart=/usr/local/bin/apply-cake.sh
