#!/bin/bash
###############################################################################
# install-simple.sh — SSH Tunnel Server (ฉบับง่าย ไม่ถามอะไรเลย)
# ใช้ IP แทนโดเมน, SSL เป็น self-signed (เพราะไม่มีโดเมนขอ Let's Encrypt ไม่ได้)
#
# วิธีใช้: sudo bash install-simple.sh
###############################################################################
set -euo pipefail
trap 'echo "[ERROR] พังที่บรรทัด $LINENO"; exit 1' ERR

[[ $EUID -eq 0 ]] || { echo "รันด้วย sudo หรือ root"; exit 1; }
log() { echo -e "\n\033[1;32m==> $*\033[0m"; }

###############################################################################
# ค่าคงที่ทั้งหมด — ไม่ถามอะไรเลย แก้ตรงนี้ได้ถ้าต้องการเปลี่ยน
###############################################################################
SYS_USER="sshadmin"
SYS_USER_PASS=$(openssl rand -base64 12)      # สุ่มรหัส user ระบบ โชว์ให้ตอนจบ
PANEL_ADMIN_USER="peepogrob555"
PANEL_ADMIN_PASS='G7!vQ2mZ9#xL4tR8@cP6nW1sD5hY3kJ9!aB8vT2mQ7zX4cN6pR1sF5dH9kL3wE'

SSH_PORT=22
DROPBEAR_PORT_PUBLIC=80
DROPBEAR_PORT_INTERNAL=109
NGINX_SSL_PORT=443
UDPGW_PORT=7300
PANEL_PORT=3000
CAKE_MBIT=350

SERVER_IP=$(curl -4 -s ifconfig.me || hostname -I | awk '{print $1}')

###############################################################################
# 1. เตรียมระบบ
###############################################################################
log "1. อัปเดตระบบ + สร้าง user"
export DEBIAN_FRONTEND=noninteractive
apt update -y && apt upgrade -y
apt install -y curl wget git build-essential cmake ufw fail2ban unzip \
  ca-certificates gnupg chrony openssl

timedatectl set-timezone Asia/Bangkok

if ! id "$SYS_USER" &>/dev/null; then
  adduser --gecos "" --disabled-password "$SYS_USER"
  echo "${SYS_USER}:${SYS_USER_PASS}" | chpasswd
  usermod -aG sudo "$SYS_USER"
fi
install -d -m 700 -o "$SYS_USER" -g "$SYS_USER" "/home/${SYS_USER}/.ssh"
touch "/home/${SYS_USER}/.ssh/authorized_keys"
chmod 600 "/home/${SYS_USER}/.ssh/authorized_keys"
chown "$SYS_USER:$SYS_USER" "/home/${SYS_USER}/.ssh/authorized_keys"

###############################################################################
# 2. Firewall
###############################################################################
log "2. ตั้ง UFW — เปิดเฉพาะพอร์ตที่ใช้จริง"
ufw default deny incoming
ufw default allow outgoing
ufw allow "${SSH_PORT}/tcp"              comment 'OpenSSH'
ufw allow "${DROPBEAR_PORT_PUBLIC}/tcp"  comment 'Dropbear'
ufw allow "${NGINX_SSL_PORT}/tcp"        comment 'Nginx SSL/WSS/Panel'
ufw allow "${UDPGW_PORT}/udp"            comment 'badvpn-udpgw'
ufw --force enable

###############################################################################
# 3. OpenSSH
###############################################################################
log "3. ตั้งค่า OpenSSH"
apt install -y openssh-server
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak.$(date +%s)
sed -i \
  -e "s/^#\?PermitRootLogin .*/PermitRootLogin no/" \
  -e "s/^#\?PasswordAuthentication .*/PasswordAuthentication yes/" \
  -e "s/^#\?MaxAuthTries .*/MaxAuthTries 3/" \
  -e "s/^#\?ClientAliveInterval .*/ClientAliveInterval 60/" \
  -e "s/^#\?ClientAliveCountMax .*/ClientAliveCountMax 3/" \
  -e "s/^#\?AllowTcpForwarding .*/AllowTcpForwarding yes/" \
  /etc/ssh/sshd_config
grep -q "^AllowTcpForwarding" /etc/ssh/sshd_config || echo "AllowTcpForwarding yes" >> /etc/ssh/sshd_config
sshd -t
systemctl restart ssh && systemctl enable ssh

###############################################################################
# 4. Dropbear
###############################################################################
log "4. ติดตั้ง Dropbear (public ${DROPBEAR_PORT_PUBLIC}, internal ${DROPBEAR_PORT_INTERNAL})"
apt install -y dropbear-bin
mkdir -p /etc/dropbear
[[ -f /etc/dropbear/dropbear_ecdsa_host_key ]] || dropbearkey -t ecdsa -f /etc/dropbear/dropbear_ecdsa_host_key
[[ -f /etc/dropbear/dropbear_rsa_host_key ]]   || dropbearkey -t rsa -s 2048 -f /etc/dropbear/dropbear_rsa_host_key
systemctl disable --now dropbear 2>/dev/null || true

cat > /etc/systemd/system/dropbear.service <<EOF
[Unit]
Description=Dropbear SSH
After=network.target
[Service]
ExecStart=/usr/sbin/dropbear -F -E -p ${DROPBEAR_PORT_PUBLIC} -p 127.0.0.1:${DROPBEAR_PORT_INTERNAL} \\
  -r /etc/dropbear/dropbear_ecdsa_host_key -r /etc/dropbear/dropbear_rsa_host_key
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now dropbear

###############################################################################
# 5. badvpn-udpgw
###############################################################################
log "5. คอมไพล์ badvpn-udpgw"
if [[ ! -f /usr/local/bin/badvpn-udpgw ]]; then
  rm -rf /usr/local/src/badvpn
  git clone --depth 1 https://github.com/ambrop72/badvpn.git /usr/local/src/badvpn
  mkdir -p /usr/local/src/badvpn/build
  cd /usr/local/src/badvpn/build
  cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1
  make -j"$(nproc)"
  cp udpgw/badvpn-udpgw /usr/local/bin/badvpn-udpgw
  cd -
fi

cat > /etc/systemd/system/badvpn-udpgw.service <<EOF
[Unit]
Description=BadVPN UDP Gateway
After=network.target
[Service]
ExecStart=/usr/local/bin/badvpn-udpgw --listen-addr 0.0.0.0:${UDPGW_PORT} --max-clients 1000 --max-connections-for-client 10
Restart=always
RestartSec=5
User=nobody
[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now badvpn-udpgw

###############################################################################
# 6. Nginx + Self-signed SSL + WebSocket
###############################################################################
log "6. ติดตั้ง Nginx + สร้าง self-signed certificate (ใช้ IP แทนโดเมน)"
apt install -y nginx
rm -f /etc/nginx/sites-enabled/default

mkdir -p /etc/nginx/ssl
if [[ ! -f /etc/nginx/ssl/selfsigned.crt ]]; then
  openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
    -keyout /etc/nginx/ssl/selfsigned.key \
    -out /etc/nginx/ssl/selfsigned.crt \
    -subj "/CN=${SERVER_IP}"
fi

cat > /etc/nginx/sites-available/ssh-tunnel.conf <<EOF
map \$http_upgrade \$connection_upgrade {
    default upgrade;
    ''      close;
}
server {
    listen ${NGINX_SSL_PORT} ssl;
    listen [::]:${NGINX_SSL_PORT} ssl;
    server_name _;

    ssl_certificate     /etc/nginx/ssl/selfsigned.crt;
    ssl_certificate_key /etc/nginx/ssl/selfsigned.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location /ssh-ws {
        proxy_pass http://127.0.0.1:${SSH_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_read_timeout 3600s;
    }
    location /dropbear-ws {
        proxy_pass http://127.0.0.1:${DROPBEAR_PORT_INTERNAL};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_read_timeout 3600s;
    }
    location /panel/ {
        proxy_pass http://127.0.0.1:${PANEL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
    location / { return 444; }
}
EOF
ln -sf /etc/nginx/sites-available/ssh-tunnel.conf /etc/nginx/sites-enabled/ssh-tunnel.conf
nginx -t
systemctl enable --now nginx
systemctl restart nginx

###############################################################################
# 7. Fail2Ban
###############################################################################
log "7. Fail2Ban"
cat > /etc/fail2ban/jail.local <<EOF
[sshd]
enabled = true
port = ${SSH_PORT}
maxretry = 4
findtime = 300
bantime = 3600
EOF
systemctl enable --now fail2ban
systemctl restart fail2ban

###############################################################################
# 8. เว็บพาแนล (Node.js) — user/pass ล็อคตายตัวตามที่กำหนด
###############################################################################
log "8. ติดตั้งเว็บพาแนลจัดการ user"
command -v node &>/dev/null || { curl -fsSL https://deb.nodesource.com/setup_20.x | bash -; apt install -y nodejs; }

PANEL_DIR=/opt/ssh-panel
mkdir -p "$PANEL_DIR/views" /usr/local/bin/ssh-panel

cat > "$PANEL_DIR/package.json" <<'EOF'
{
  "name": "ssh-tunnel-panel",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": { "start": "node server.js" },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0"
  }
}
EOF

cat > "$PANEL_DIR/server.js" <<'EOF'
require('dotenv').config();
const express = require('express');
const session = require('express-session');
const rateLimit = require('express-rate-limit');
const bcrypt = require('bcryptjs');
const { execFile } = require('child_process');
const path = require('path');

const app = express();
const PORT = process.env.PANEL_PORT || 3000;
const ADMIN_USER = process.env.ADMIN_USER;
const ADMIN_PASS_HASH = process.env.ADMIN_PASS_HASH;
const SESSION_SECRET = process.env.SESSION_SECRET;

const SCRIPTS = {
  add: '/usr/local/bin/ssh-panel/adduser.sh',
  del: '/usr/local/bin/ssh-panel/deluser.sh',
  list: '/usr/local/bin/ssh-panel/listusers.sh',
  online: '/usr/local/bin/ssh-panel/onlineusers.sh',
};

app.set('trust proxy', 1);
app.use(express.json());
app.use(session({
  secret: SESSION_SECRET,
  resave: false,
  saveUninitialized: false,
  cookie: { httpOnly: true, secure: true, sameSite: 'strict', maxAge: 1000 * 60 * 60 * 4 },
}));

const loginLimiter = rateLimit({ windowMs: 15 * 60 * 1000, max: 5 });
function requireAuth(req, res, next) {
  if (req.session && req.session.authed) return next();
  return res.status(401).json({ error: 'Unauthorized' });
}
const usernameRe = /^[a-z][a-z0-9_-]{2,31}$/;
const validUsername = u => typeof u === 'string' && usernameRe.test(u);
const validPassword = p => typeof p === 'string' && p.length >= 6 && p.length <= 128 && !/\s/.test(p);

function runScript(scriptPath, args, res) {
  execFile('sudo', [scriptPath, ...args], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ ok: true, message: stdout.trim() });
  });
}

app.get('/', (req, res) => {
  res.sendFile(path.join(__dirname, 'views', req.session?.authed ? 'dashboard.html' : 'login.html'));
});

app.post('/api/login', loginLimiter, async (req, res) => {
  const { username, password } = req.body || {};
  if (username !== ADMIN_USER || !(await bcrypt.compare(password || '', ADMIN_PASS_HASH))) {
    return res.status(401).json({ error: 'Username หรือ Password ไม่ถูกต้อง' });
  }
  req.session.regenerate(err => {
    if (err) return res.status(500).json({ error: 'error' });
    req.session.authed = true;
    res.json({ ok: true });
  });
});
app.post('/api/logout', (req, res) => req.session.destroy(() => res.json({ ok: true })));

app.get('/api/users', requireAuth, (req, res) => {
  execFile('sudo', [SCRIPTS.list], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ users: stdout.trim().split('\n').filter(Boolean) });
  });
});
app.get('/api/online', requireAuth, (req, res) => {
  execFile('sudo', [SCRIPTS.online], { timeout: 10000 }, (err, stdout, stderr) => {
    if (err) return res.status(500).json({ error: (stderr || err.message).trim() });
    res.json({ online: stdout.trim() });
  });
});
app.post('/api/users', requireAuth, (req, res) => {
  const { username, password } = req.body || {};
  if (!validUsername(username)) return res.status(400).json({ error: 'Username ไม่ถูกต้อง' });
  if (!validPassword(password)) return res.status(400).json({ error: 'Password ไม่ถูกต้อง' });
  runScript(SCRIPTS.add, [username, password], res);
});
app.delete('/api/users/:username', requireAuth, (req, res) => {
  if (!validUsername(req.params.username)) return res.status(400).json({ error: 'Username ไม่ถูกต้อง' });
  runScript(SCRIPTS.del, [req.params.username], res);
});

app.listen(PORT, '127.0.0.1', () => console.log(`Panel on 127.0.0.1:${PORT}`));
EOF

