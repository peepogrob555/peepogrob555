# ── Jitter test ──────────────────────────────────────────────────
do_jitter() {
    local TARGET=${2:-8.8.8.8}
    echo ""
    echo -e "${BOLD}Jitter Test → ${TARGET} (60 pings @ 0.2s)${NC}"
    echo ""
    ping -c 60 -i 0.2 "$TARGET"
    echo ""
    echo -e "  ${G}mdev < 3ms${NC}  excellent"
    echo -e "  ${Y}mdev 3-10ms${NC} ยอมรับได้"
    echo -e "  ${R}mdev > 10ms${NC} unstable"
}

# ── Rollback ─────────────────────────────────────────────────────
do_rollback() {
    echo ""
    echo -e "${BOLD}${Y}Rollback — ลบ CAKE + sysctl (ไม่แตะ Nginx/Xray/cert)${NC}"
    echo ""
    echo -ne "  Continue? [y/N]: "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }

    local NIC_R
    NIC_R=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true

    tc qdisc del dev "$NIC_R" root    2>/dev/null && echo -e "  ${G}✔ egress removed${NC}"  || true
    tc qdisc del dev "$NIC_R" ingress 2>/dev/null && echo -e "  ${G}✔ ingress removed${NC}" || true
    if ip link show ifb0 &>/dev/null; then
        tc qdisc del dev ifb0 root 2>/dev/null || true
        ip link del ifb0 2>/dev/null && echo -e "  ${G}✔ ifb0 removed${NC}" || true
    fi

    rm -f /etc/sysctl.d/99-vmess-ais.conf
    sysctl --system >> /dev/null 2>&1 || true
    echo -e "  ${G}✔ sysctl reset${NC}"

    systemctl disable vmess-cake.service 2>/dev/null && \
        echo -e "  ${G}✔ vmess-cake disabled${NC}" || true

    echo ""
    echo -e "  ${G}Done.${NC}"
}

# ── Main ─────────────────────────────────────────────────────────
main_install() {
    [[ $EUID -eq 0 ]] || { echo "Run as root: sudo bash $0"; exit 1; }
    mkdir -p "$(dirname "$LOG")"
    touch "$LOG"

    _banner

    _safe_step "Detect NIC"       do_detect_nic
    _safe_step "Domain config"    do_get_domain
    _safe_step "System update"    do_system_update
    _safe_step "Kernel modules"   do_kernel_modules
    _safe_step "Install 3X-UI"    do_install_xui
    _safe_step "Panel port"       do_panel_port
    _safe_step "TLS cert"         do_tls_cert
    _safe_step "Nginx config"     do_nginx_config
    _safe_step "Xray config"      do_xray_config
    _safe_step "sysctl tuning"    do_sysctl
    _safe_step "CAKE AQM"         do_cake_aqm
    _safe_step "System limits"    do_limits
    _safe_step "Firewall + Start" do_firewall_and_start

    do_summary
}

# ── Dispatch ─────────────────────────────────────────────────────
CMD=${1:-install}

case "$CMD" in
    install|"")      main_install ;;
    monitor)         do_monitor ;;
    status)          do_status ;;
    jitter)          do_jitter "$@" ;;
    rollback)        do_rollback ;;
    inject-inbound)  do_inject_inbound ;;
    cake)
        NIC_C=$(ip route get 1.1.1.1 | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true
        tc -s qdisc show dev "$NIC_C"
        ip link show ifb0 &>/dev/null && tc -s qdisc show dev ifb0
        ;;
    bbr)
        sysctl net.ipv4.tcp_congestion_control
        sysctl net.core.default_qdisc
        sysctl net.ipv4.tcp_notsent_lowat
        ss -tni 2>/dev/null | grep -E "bbr|cubic" | head -10
        ;;
    help|--help|-h)
        echo ""
        echo -e "${BOLD}Usage:${NC}  sudo bash $0 [command]"
        echo ""
        echo -e "  ${C}(no args)${NC}        ติดตั้ง"
        echo -e "  ${C}monitor${NC}          live dashboard"
        echo -e "  ${C}status${NC}           ตรวจสอบด่วน"
