        echo -e "${BOLD}${B}╔═══════════════════════════════════════════════════════╗${NC}"
        printf "${BOLD}${B}║${NC}${BOLD}  VMESS Monitor — ReadyIDC นนทบุรี         %s  ${BOLD}${B}║${NC}\n" "$(date '+%H:%M:%S')"
        echo -e "${BOLD}${B}╚═══════════════════════════════════════════════════════╝${NC}"
        echo ""

        echo -e "${BOLD}  Services:${NC}"
        for svc in nginx x-ui; do
            systemctl is-active --quiet "$svc" && \
                printf "    ${G}✔ %-10s running${NC}\n" "$svc" || \
                printf "    ${R}✘ %-10s DEAD${NC}\n" "$svc"
        done
        echo ""

        local WS_C HTTPS_C
        WS_C=$(ss -tnp 2>/dev/null | grep -c ":${XRAY_INTERNAL_PORT}[[:space:]]" || echo 0)
        HTTPS_C=$(ss -tnp 2>/dev/null | grep -c ":443[[:space:]]" || echo 0)
        echo -e "${BOLD}  Connections:${NC}"
        echo -e "    Xray WS  : ${C}${WS_C}${NC}"
        echo -e "    HTTPS    : ${C}${HTTPS_C}${NC}"
        echo ""

        echo -e "${BOLD}  Throughput (1s):${NC}"
        local R1 T1 R2 T2
        R1=$(cat /sys/class/net/"$NIC_M"/statistics/rx_bytes 2>/dev/null || echo 0)
        T1=$(cat /sys/class/net/"$NIC_M"/statistics/tx_bytes 2>/dev/null || echo 0)
        sleep 1
        R2=$(cat /sys/class/net/"$NIC_M"/statistics/rx_bytes 2>/dev/null || echo 0)
        T2=$(cat /sys/class/net/"$NIC_M"/statistics/tx_bytes 2>/dev/null || echo 0)
        echo -e "    RX: ${C}$(( (R2-R1)*8/1024 )) kbps${NC}"
        echo -e "    TX: ${C}$(( (T2-T1)*8/1024 )) kbps${NC}"
        echo ""

        echo -e "${BOLD}  CAKE:${NC}"
        tc qdisc show dev "$NIC_M" 2>/dev/null | grep -q cake && \
            echo -e "    ${G}✔ active${NC}" || echo -e "    ${Y}⚠ ไม่ active${NC}"
        echo ""

        echo -e "${BOLD}  TCP:${NC}"
        local CC NL RT
        CC=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null) || CC="?"
        NL=$(sysctl -n net.ipv4.tcp_notsent_lowat 2>/dev/null) || NL="?"
        RT=$(awk '/^Tcp:/{getline; print $13}' /proc/net/snmp 2>/dev/null || echo 0)
        echo -e "    cc=$CC  notsent_lowat=${NL}  retransmits=${RT}"
        echo ""

        local MF MT
        MF=$(free -m | awk '/^Mem:/{print $4}')
        MT=$(free -m | awk '/^Mem:/{print $2}')
        echo -e "${BOLD}  Memory:${NC}  ${C}${MF}/${MT} MB${NC}"
        echo ""
        echo -e "  ${DIM}Ctrl+C to exit${NC}"
        sleep 2
    done
}

# ── Status ───────────────────────────────────────────────────────
do_status() {
    echo ""
    echo -e "${BOLD}Quick Status:${NC}"
    echo ""

    local NIC_S
    NIC_S=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true

    for svc in nginx x-ui; do
        systemctl is-active --quiet "$svc" && \
            echo -e "  ${G}✔ $svc${NC}" || echo -e "  ${R}✘ $svc${NC}"
    done

    for port in 80 443 "$PANEL_PORT" "$XRAY_INTERNAL_PORT"; do
        ss -tlnp 2>/dev/null | grep -q ":${port}[[:space:]]" && \
            echo -e "  ${G}✔ port $port${NC}" || \
            echo -e "  ${Y}⚠ port $port ไม่ listen${NC}"
    done

    tc qdisc show dev "$NIC_S" 2>/dev/null | grep -q cake && \
        echo -e "  ${G}✔ CAKE active${NC}" || echo -e "  ${Y}⚠ CAKE ไม่ active${NC}"

    local CC
    CC=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null) || CC="?"
    [[ "$CC" == "bbr" ]] && echo -e "  ${G}✔ BBR${NC}" || echo -e "  ${Y}⚠ cc=$CC${NC}"

    local XUI_DB="/etc/x-ui/x-ui.db"
    if [[ -f "$XUI_DB" ]] && command -v sqlite3 &>/dev/null; then
        local IB_COUNT
        IB_COUNT=$(sqlite3 "$XUI_DB" \
            "SELECT COUNT(*) FROM inbounds WHERE port=${XRAY_INTERNAL_PORT};" 2>/dev/null) || IB_COUNT=0
        [[ "$IB_COUNT" -gt 0 ]] && \
            echo -e "  ${G}✔ 3X-UI inbound OK${NC}" || \
            echo -e "  ${Y}⚠ inbound ไม่พบ → bash ${SCRIPT_PATH} inject-inbound${NC}"
    fi

    echo ""
    [[ -f /root/vmess-info.txt ]] && cat /root/vmess-info.txt
}

# ── Jitter test ──────────────────────────────────────────────────
do_jitter() {
    local TARGET=${2:-8.8.8.8}
    echo ""
    echo -e "${BOLD}Jitter Test → ${TARGET} (60 pings @ 0.2s)${NC}"
    echo ""
    ping -c 60 -i 0.2 "$TARGET"
    echo ""
    echo -e "  ${G}mdev < 3ms${NC}  excellent"
    echo -e "  ${Y}mdev 3-10ms${NC} ยอมรับได้"
    echo -e "  ${R}mdev > 10ms${NC} unstable"
}

# ── Rollback ─────────────────────────────────────────────────────
do_rollback() {
    echo ""
    echo -e "${BOLD}${Y}Rollback — ลบ CAKE + sysctl (ไม่แตะ Nginx/Xray/cert)${NC}"
    echo ""
    echo -ne "  Continue? [y/N]: "
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }

    local NIC_R
    NIC_R=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true

    tc qdisc del dev "$NIC_R" root    2>/dev/null && echo -e "  ${G}✔ egress removed${NC}"  || true
    tc qdisc del dev "$NIC_R" ingress 2>/dev/null && echo -e "  ${G}✔ ingress removed${NC}" || true
    if ip link show ifb0 &>/dev/null; then
        tc qdisc del dev ifb0 root 2>/dev/null || true
        ip link del ifb0 2>/dev/null && echo -e "  ${G}✔ ifb0 removed${NC}" || true
    fi

    rm -f /etc/sysctl.d/99-vmess-ais.conf
    sysctl --system >> /dev/null 2>&1 || true
    echo -e "  ${G}✔ sysctl reset${NC}"

    systemctl disable vmess-cake.service 2>/dev/null && \
        echo -e "  ${G}✔ vmess-cake disabled${NC}" || true

    echo ""
    echo -e "  ${G}Done.${NC}"
}

# ── Main ─────────────────────────────────────────────────────────
main_install() {
    [[ $EUID -eq 0 ]] || { echo "Run as root: sudo bash $0"; exit 1; }
    mkdir -p "$(dirname "$LOG")"
    touch "$LOG"

    _banner

    _safe_step "Detect NIC"       do_detect_nic
    _safe_step "Domain config"    do_get_domain
    _safe_step "System update"    do_system_update
    _safe_step "Kernel modules"   do_kernel_modules
    _safe_step "Install 3X-UI"    do_install_xui
    _safe_step "Panel port"       do_panel_port
    _safe_step "TLS cert"         do_tls_cert
    _safe_step "Nginx config"     do_nginx_config
    _safe_step "Xray config"      do_xray_config
    _safe_step "sysctl tuning"    do_sysctl
    _safe_step "CAKE AQM"         do_cake_aqm
    _safe_step "System limits"    do_limits
    _safe_step "Firewall + Start" do_firewall_and_start

    do_summary
}

# ── Dispatch ─────────────────────────────────────────────────────
CMD=${1:-install}

case "$CMD" in
    install|"")      main_install ;;
    monitor)         do_monitor ;;
    status)          do_status ;;
    jitter)          do_jitter "$@" ;;
    rollback)        do_rollback ;;
    inject-inbound)  do_inject_inbound ;;
    certbot-renew)
        # รัน certbot ด้วย cert จริงหลัง DDNS อัพเดตแล้ว
        [[ -z "${2:-}" ]] && { echo "Usage: bash $0 certbot-renew <domain>"; exit 1; }
        RENEW_DOMAIN="${2}"
        echo -e "${BOLD}Re-issue cert สำหรับ ${RENEW_DOMAIN}${NC}"
        systemctl stop nginx 2>/dev/null || true
        fuser -k 80/tcp 2>/dev/null || true
        sleep 1
        certbot certonly --standalone --preferred-challenges http \
            --non-interactive --agree-tos \
            --email "${3:-admin@${RENEW_DOMAIN}}" \
            -d "$RENEW_DOMAIN" && \
            systemctl start nginx && \
            echo -e "${G}  ✔ Cert issued + Nginx restarted${NC}" || \
            echo -e "${R}  ✘ ล้มเหลว — ตรวจสอบ DNS อีกครั้ง${NC}"
        ;;
    cake)
        NIC_C=$(ip route get 1.1.1.1 | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true
        tc -s qdisc show dev "$NIC_C"
        ip link show ifb0 &>/dev/null && tc -s qdisc show dev ifb0
        ;;
    bbr)
        sysctl net.ipv4.tcp_congestion_control
        sysctl net.core.default_qdisc
        sysctl net.ipv4.tcp_notsent_lowat
        ss -tni 2>/dev/null | grep -E "bbr|cubic" | head -10
        ;;
    help|--help|-h)
        echo ""
        echo -e "${BOLD}Usage:${NC}  sudo bash $0 [command]"
        echo ""
        echo -e "  ${C}(no args)${NC}        ติดตั้ง"
        echo -e "  ${C}monitor${NC}          live dashboard"
        echo -e "  ${C}status${NC}           ตรวจสอบด่วน"
        echo -e "  ${C}jitter [IP]${NC}      ทดสอบ jitter"
        echo -e "  ${C}inject-inbound${NC}               re-inject inbound เข้า 3X-UI DB"
        echo -e "  ${C}certbot-renew <domain> [email]${NC} ออก Let's Encrypt cert หลัง DDNS อัพเดต"
        echo -e "  ${C}cake${NC}                          CAKE stats"
        echo -e "  ${C}bbr${NC}              BBR/TCP stats"
        echo -e "  ${C}rollback${NC}         ยกเลิก tuning"
        echo ""
        ;;
    *)
        echo "Unknown: $CMD  |  bash $0 help"
        exit 1
        ;;
esac
