# ── Step 13: Firewall + Start ────────────────────────────────────
do_firewall_and_start() {
    _step "Firewall (ufw) + Start all services"

    ufw --force reset               >> "$LOG" 2>&1 || true
    ufw allow ssh                   >> "$LOG" 2>&1 || true
    ufw allow 80/tcp                >> "$LOG" 2>&1 || true
    ufw allow 443/tcp               >> "$LOG" 2>&1 || true
    ufw allow "${PANEL_PORT}/tcp"   >> "$LOG" 2>&1 || true
    ufw --force enable              >> "$LOG" 2>&1 || true

    _ok "UFW configured"
    _dim "22    SSH"
    _dim "80    VMESS WS plain (fallback)"
    _dim "443   VMESS WS TLS (หลัก)"
    _dim "${PANEL_PORT}   3X-UI panel"
    _dim "${XRAY_INTERNAL_PORT}  Xray internal (localhost only)"

    echo ""
    _info "Starting services..."

    echo ""
    echo -e "${DIM}  ── nginx start ───────────────────────────────────────${NC}"
    if systemctl restart nginx 2>&1 | tee -a "$LOG" | sed 's/^/    /'; then
        systemctl enable nginx >> "$LOG" 2>&1 || true
        _ok "Nginx started"
    else
        _fail "Nginx ไม่ start — ดู log:"
        journalctl -u nginx -n 15 --no-pager | sed 's/^/    /'
        return 1
    fi

    echo ""
    echo -e "${DIM}  ── x-ui start ────────────────────────────────────────${NC}"
    if systemctl restart x-ui 2>&1 | tee -a "$LOG" | sed 's/^/    /'; then
        systemctl enable x-ui >> "$LOG" 2>&1 || true
        sleep 3  # รอ x-ui initialize DB และ bind port
        _ok "x-ui started"
    else
        _fail "x-ui ไม่ start — ดู log:"
        journalctl -u x-ui -n 15 --no-pager | sed 's/^/    /'
        return 1
    fi
}

