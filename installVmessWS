# ── Summary ──────────────────────────────────────────────────────
do_summary() {
    echo ""
    echo -e "${BOLD}${G}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${G}║              HEALTH CHECK                            ║${NC}"
    echo -e "${BOLD}${G}╚══════════════════════════════════════════════════════╝${NC}"
    echo ""

    # wait ให้ x-ui bind port
    sleep 2

    for svc in nginx x-ui; do
        systemctl is-active --quiet "$svc" && \
            echo -e "  ${G}✔ $svc running${NC}" || \
            echo -e "  ${R}✘ $svc NOT running${NC}  → journalctl -u $svc -n 20"
    done

    for port in 80 443 "$PANEL_PORT" "$XRAY_INTERNAL_PORT"; do
        ss -tlnp 2>/dev/null | grep -q ":${port}[[:space:]]" && \
            echo -e "  ${G}✔ port $port listening${NC}" || \
            echo -e "  ${Y}⚠ port $port ไม่ listening${NC}"
