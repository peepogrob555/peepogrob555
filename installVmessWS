#!/usr/bin/env bash
# VMESS WS — AIS Thailand Mobile VPN
# ReadyIDC นนทบุรี | 2 Users | BBR + CAKE AQM | Ubuntu 22.04
#
# Usage:
#   sudo bash vmess-ais-setup.sh
#   sudo bash vmess-ais-setup.sh monitor
#   sudo bash vmess-ais-setup.sh status
#   sudo bash vmess-ais-setup.sh rollback
#   sudo bash vmess-ais-setup.sh inject-inbound
#   sudo bash vmess-ais-setup.sh jitter [IP]

set -uo pipefail
IFS=$'\n\t'

# ต้องเก็บก่อน $0 กลายเป็น /dev/fd หรือ /proc/... ตอนรันผ่าน pipe
SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
# ถ้ารันผ่าน pipe (bash <(curl...)) จะได้ /dev/fd/N หรือ /proc/.../fd/N
case "$SCRIPT_PATH" in
    /proc/*|/dev/fd/*|/dev/stdin) SCRIPT_PATH="$(pwd)/vmess-ais-setup.sh" ;;
esac

R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
B='\033[0;34m' C='\033[0;36m' M='\033[0;35m'
W='\033[1;37m' DIM='\033[2m'  NC='\033[0m' BOLD='\033[1m'

XRAY_INTERNAL_PORT=10086
PANEL_PORT=2053
WS_PATH="/speedtest"
LOG=/var/log/vmess-setup.log

TOTAL_STEPS=13
CUR_STEP=0
NIC=""
DOMAIN=""
CERT_EMAIL=""
VPS_IP=""
UUID1=""
UUID2=""
FAILED_STEPS=()
WARN_STEPS=()

# ── Utilities ────────────────────────────────────────────────────
_log()  { echo "[$(date '+%H:%M:%S')] $*" >> "$LOG"; }
_info() { echo -e "${C}  ●  $*${NC}"; _log "INFO: $*"; }
_ok()   { echo -e "${G}  ✔  $*${NC}"; _log "OK: $*"; }
_warn() { echo -e "${Y}  ⚠  $*${NC}"; _log "WARN: $*"; }
_fail() { echo -e "${R}  ✘  $*${NC}"; _log "FAIL: $*"; }
_dim()  { echo -e "${DIM}     $*${NC}"; }

_spin() {
    local pid=$1 msg=$2
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${C}%s${NC}  %s   " "${frames[i++ % ${#frames[@]}]}" "$msg"
        sleep 0.08
    done
    printf "\r%60s\r" ""
}

# _run: รัน command ใน background + spinner + log output ทุก line แบบ real-time
_run() {
    local label=$1; shift
    # pipe stdout+stderr → tee → log  แล้วเก็บ exit code จาก command จริง
    local tmp_rc
    tmp_rc=$(mktemp)
    (
        "$@" 2>&1
        echo $? > "$tmp_rc"
    ) | while IFS= read -r line; do
        echo "    $line"
        echo "[$(date '+%H:%M:%S')] $line" >> "$LOG"
    done &
    local pid=$!
    # spinner วิ่งคู่ขนาน (แสดงแค่ตอน tty)
    if [[ -t 1 ]]; then
        _spin $pid "$label"
    fi
    wait $pid 2>/dev/null || true
    local rc=0
    [[ -f "$tmp_rc" ]] && rc=$(cat "$tmp_rc") || rc=1
    rm -f "$tmp_rc"
    if [[ $rc -eq 0 ]]; then
        _ok "$label"; return 0
    else
        _fail "$label"; return 1
    fi
}

_step() {
    CUR_STEP=$((CUR_STEP + 1))
    local pct=$(( CUR_STEP * 100 / TOTAL_STEPS ))
    local filled=$(( pct * 24 / 100 ))
    local bar="" i
    for ((i=0; i<filled; i++));  do bar+="█"; done
    for ((i=filled; i<24; i++)); do bar+="░"; done
    echo ""
    echo -e "${BOLD}${B}┌─ [${CUR_STEP}/${TOTAL_STEPS}] $1${NC}"
    printf "${B}│${NC} ${G}%s${NC} ${DIM}%d%%${NC}\n" "$bar" "$pct"
    echo -e "${B}└${NC}"
    _log "═══ STEP ${CUR_STEP}/${TOTAL_STEPS}: $1 ═══"
}

_safe_step() {
    local name=$1; shift
    local rc=0
    "$@" || rc=$?
    if [[ $rc -ne 0 ]]; then
        FAILED_STEPS+=("Step ${CUR_STEP}: ${name}")
        echo -e "${R}  ✘  Step นี้พัง (exit $rc) — ข้ามต่อไป จะสรุปตอนท้าย${NC}"
        _log "STEP FAILED: $name (exit $rc)"
        return 1
    fi
    return 0
}

# ── Banner ───────────────────────────────────────────────────────
_banner() {
    clear
    echo ""
    echo -e "${BOLD}${B}  ╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${B}  ║${NC}${BOLD}${W}   VMESS WS Setup — AIS Thailand 128kbps Mobile VPN  ${NC}${BOLD}${B}║${NC}"
    echo -e "${BOLD}${B}  ║${NC}${DIM}   ReadyIDC นนทบุรี · 2 Users · BBR + CAKE AQM        ${NC}${BOLD}${B}║${NC}"
    echo -e "${BOLD}${B}  ╚══════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${DIM}  Log: ${LOG}${NC}"
    echo ""
}

# ── Step 1: Detect NIC ───────────────────────────────────────────
do_detect_nic() {
    _step "Detecting network interface + public IP"

    NIC=$(ip route get 1.1.1.1 2>/dev/null \
        | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' \
        | head -1) || true
    if [[ -z "$NIC" ]]; then
        NIC=$(ip link show \
            | awk -F': ' '/^[0-9]+: (eth|ens|enp|eno|veth)/{print $2}' \
            | grep -v lo | head -1) || true
    fi
    [[ -z "$NIC" ]] && { _fail "หา NIC ไม่เจอ"; return 1; }

    VPS_IP=$(curl -s --max-time 8 https://api.ipify.org 2>/dev/null \
          || curl -s --max-time 8 https://ifconfig.me 2>/dev/null \
          || ip addr show "$NIC" | awk '/inet /{print $2}' | cut -d/ -f1 | head -1) || true
    [[ -z "$VPS_IP" ]] && { _fail "หา public IP ไม่ได้"; return 1; }

    _ok "Interface: ${BOLD}${NIC}${NC}  |  IP: ${BOLD}${VPS_IP}${NC}"
}

# ── Step 2: Domain input ─────────────────────────────────────────
do_get_domain() {
    _step "Domain + TLS certificate configuration"

    echo ""
    echo -e "  ${BOLD}VPS IP ของคุณ: ${C}${VPS_IP}${NC}"
    echo -e "  ${Y}ตรวจสอบว่า A record ของ domain ชี้มาที่ IP นี้ก่อน${NC}"
    echo ""

    while true; do
        echo -ne "  ${BOLD}กรอก domain (เช่น sub.example.com): ${NC}"
        read -r DOMAIN
        [[ -n "$DOMAIN" ]] && break
        echo -e "  ${R}domain ห้ามว่าง${NC}"
    done

    while true; do
        echo -ne "  ${BOLD}กรอก email สำหรับ Let's Encrypt cert: ${NC}"
        read -r CERT_EMAIL
        [[ -n "$CERT_EMAIL" && "$CERT_EMAIL" == *"@"* ]] && break
        echo -e "  ${R}กรุณากรอก email จริง (เช่น user@gmail.com)${NC}"
    done

    _ok "Domain: ${BOLD}${DOMAIN}${NC}"
}

# ── Step 3: System update ────────────────────────────────────────
do_system_update() {
    _step "System update + base packages"

    export DEBIAN_FRONTEND=noninteractive

    _run "apt-get update"      apt-get update -y || return 1
    _run "apt-get upgrade"     apt-get upgrade -y \
        -o Dpkg::Options::="--force-confdef" \
        -o Dpkg::Options::="--force-confold" || return 1
    _run "Installing packages" apt-get install -y \
        curl wget unzip git socat openssl \
        nginx certbot python3-certbot-nginx \
        iproute2 iptables nftables \
        net-tools htop iotop dstat \
        cron logrotate ufw sqlite3 \
        build-essential python3 || return 1

    _ok "Packages installed"
}

# ── Step 4: Kernel modules ───────────────────────────────────────
do_kernel_modules() {
    _step "Kernel modules (BBR + CAKE + IFB)"

    local mods=(tcp_bbr sch_cake ifb sch_fq)
    for m in "${mods[@]}"; do
        if lsmod | grep -q "^${m}"; then
            _ok "Module ${m} — already loaded"
        else
            if modprobe "$m" 2>/dev/null; then
                _ok "Loaded: ${m}"
            else
                _warn "Cannot load ${m} — may use fallback"
                WARN_STEPS+=("kernel module ${m} ไม่สามารถโหลดได้")
            fi
        fi
    done

    cat > /etc/modules-load.d/vmess-modules.conf << 'EOF'
tcp_bbr
sch_cake
ifb
sch_fq
EOF
    _ok "Modules persisted across reboot"
}

# ── Step 5: Install 3X-UI ────────────────────────────────────────
do_install_xui() {
    _step "Installing 3X-UI + Xray-core"

    # ── ตรวจว่า install แล้วหรือยัง ──────────────────────────
    if command -v x-ui &>/dev/null && systemctl list-unit-files x-ui.service &>/dev/null; then
        _ok "3X-UI มีอยู่แล้ว — ข้าม install"
        return 0
    fi

    local ARCH
    ARCH=$(uname -m)
    [[ "$ARCH" == "x86_64" ]] && ARCH="amd64" || ARCH="arm64"

    # ── ดึง latest version tag จาก GitHub API ──────────────────
    _info "ตรวจ latest version..."
    local VER
    VER=$(curl -s --max-time 10 \
        https://api.github.com/repos/mhsanaei/3x-ui/releases/latest \
        | grep '"tag_name"' | cut -d'"' -f4) || VER=""
    [[ -z "$VER" ]] && VER="latest"
    _dim "Version: ${VER}"

    local DL_URL="https://github.com/mhsanaei/3x-ui/releases/latest/download/x-ui-linux-${ARCH}.tar.gz"
    local TMP_DIR
    TMP_DIR=$(mktemp -d)

    # ── Download ───────────────────────────────────────────────
    _info "Downloading x-ui-linux-${ARCH}.tar.gz..."
    echo ""
    if ! curl -L --progress-bar "$DL_URL" \
         -o "${TMP_DIR}/x-ui.tar.gz" 2>&1 | tee -a "$LOG" | sed 's/^/    /'; then
        _fail "ดาวน์โหลดล้มเหลว: ${DL_URL}"
        rm -rf "$TMP_DIR"
        return 1
    fi
    echo ""

    # ── Extract ────────────────────────────────────────────────
    _info "Extracting..."
    if ! tar -xzf "${TMP_DIR}/x-ui.tar.gz" -C "${TMP_DIR}" 2>>"$LOG"; then
        _fail "Extract ล้มเหลว — ไฟล์อาจ corrupt"
        rm -rf "$TMP_DIR"
        return 1
    fi

    [[ -f "${TMP_DIR}/x-ui/x-ui" ]] || {
        _fail "ไม่พบ x-ui binary หลัง extract"
        _dim  "Contents: $(ls "${TMP_DIR}/" 2>/dev/null)"
        rm -rf "$TMP_DIR"
        return 1
    }

    # ── Install files ──────────────────────────────────────────
    systemctl stop x-ui 2>/dev/null || true
    mkdir -p /usr/local/x-ui /etc/x-ui
    cp -r "${TMP_DIR}/x-ui/"* /usr/local/x-ui/
    ln -sf /usr/local/x-ui/x-ui /usr/bin/x-ui
    chmod +x /usr/local/x-ui/x-ui
    find /usr/local/x-ui/bin/ -name "xray-linux-*" -exec chmod +x {} \; 2>/dev/null || true
    rm -rf "$TMP_DIR"

    # ── Systemd unit ───────────────────────────────────────────
    cat > /etc/systemd/system/x-ui.service << 'XUISVC'
[Unit]
Description=3X-UI Panel Service
After=network.target nss-lookup.target

[Service]
Type=simple
WorkingDirectory=/usr/local/x-ui/
ExecStart=/usr/local/x-ui/x-ui
Restart=on-failure
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
XUISVC

    systemctl daemon-reload
    _ok "3X-UI ${VER} installed (arch: ${ARCH})"
    _dim "Binary: /usr/local/x-ui/x-ui"
    _dim "Service: /etc/systemd/system/x-ui.service"
}

# ── Step 6: Panel port ───────────────────────────────────────────
do_panel_port() {
    _step "Configure 3X-UI panel port → ${PANEL_PORT}"

    # start x-ui ชั่วคราวเพื่อให้ DB initialize ก่อน
    systemctl start x-ui 2>/dev/null || true
    sleep 3

    local XUI_DB="/etc/x-ui/x-ui.db"

    if command -v x-ui &>/dev/null; then
        # x-ui setting เขียนลง DB โดยตรง ต้อง stop ก่อนแก้
        systemctl stop x-ui 2>/dev/null || true
        sleep 1
        x-ui setting -port "$PANEL_PORT" >> "$LOG" 2>&1 || true
        x-ui setting -username "admin"   >> "$LOG" 2>&1 || true
        _ok "Panel port set via x-ui CLI: ${PANEL_PORT}"
    elif [[ -f "$XUI_DB" ]] && command -v sqlite3 &>/dev/null; then
        systemctl stop x-ui 2>/dev/null || true
        sleep 1
        # แก้ port โดยตรงใน settings table
        sqlite3 "$XUI_DB" \
            "UPDATE settings SET value='${PANEL_PORT}' WHERE key='webPort';" \
            2>>"$LOG" || true
        _ok "Panel port patched via SQLite: ${PANEL_PORT}"
    else
        _warn "ไม่สามารถ set panel port — x-ui DB ยังไม่ถูกสร้าง"
        _warn "หลัง install เสร็จ ให้เข้า panel แล้วเปลี่ยน port เป็น ${PANEL_PORT} เอง"
        WARN_STEPS+=("Panel port ยังไม่ถูก set — เปลี่ยนเองใน panel setting")
    fi
}

# ── Step 7: TLS cert ─────────────────────────────────────────────
do_tls_cert() {
    _step "Let's Encrypt TLS certificate for ${DOMAIN}"

    # หยุดทุกอย่างที่ใช้ port 80
    systemctl stop nginx 2>/dev/null || true
    systemctl stop x-ui  2>/dev/null || true
    fuser -k 80/tcp      2>/dev/null || true
    sleep 2

    # ── ตรวจ DNS ก่อนรัน certbot ──────────────────────────────
    _info "ตรวจ DNS: ${DOMAIN} → ?"
    local RESOLVED_IP
    RESOLVED_IP=$(dig +short "$DOMAIN" A 2>/dev/null | tail -1) || \
    RESOLVED_IP=$(host "$DOMAIN" 2>/dev/null | awk '/has address/{print $NF}' | tail -1) || \
    RESOLVED_IP=""

    if [[ -z "$RESOLVED_IP" ]]; then
        _warn "DNS resolve ไม่ได้ — DDNS อาจยังไม่อัพเดต"
    elif [[ "$RESOLVED_IP" != "$VPS_IP" ]]; then
        _warn "DNS ชี้ไปที่ ${RESOLVED_IP} แต่ VPS IP คือ ${VPS_IP}"
        _warn "DDNS ยังไม่อัพเดต — certbot อาจล้มเหลว"
    else
        _ok "DNS OK: ${DOMAIN} → ${RESOLVED_IP}"
    fi

    echo ""
    echo -e "${DIM}  ── certbot output ────────────────────────────────────${NC}"

    local CERT_OK=false
    if certbot certonly \
        --standalone \
        --preferred-challenges http \
        --non-interactive \
        --agree-tos \
        --email "$CERT_EMAIL" \
        -d "$DOMAIN" \
        2>&1 | tee -a "$LOG" | sed 's/^/    /'; then
        CERT_OK=true
    fi
    echo -e "${DIM}  ────────────────────────────────────────────────────${NC}"

    local CERT_PATH="/etc/letsencrypt/live/${DOMAIN}/fullchain.pem"

    if $CERT_OK && [[ -f "$CERT_PATH" ]]; then
        _ok "TLS cert issued (Let's Encrypt)"
        (crontab -l 2>/dev/null; \
         echo "30 3 * * * certbot renew --quiet --post-hook 'systemctl reload nginx'") \
            | sort -u | crontab -
        _ok "Auto-renewal cron configured"
        return 0
    fi

    # ── Fallback: self-signed cert ────────────────────────────
    _warn "certbot ล้มเหลว — สร้าง self-signed cert แทน"
    _warn "Nginx จะ start ได้ แต่ browser จะเตือน 'Not Secure'"
    _warn "แก้ภายหลัง: certbot certonly --standalone -d ${DOMAIN}"
    _dim  "สาเหตุที่พบบ่อย: DDNS ยังไม่อัพเดต IP (รอ 1-5 นาที แล้วรัน certbot อีกครั้ง)"

    local SS_DIR="/etc/ssl/vmess"
    mkdir -p "$SS_DIR"

    openssl req -x509 -nodes -newkey rsa:2048 \
        -keyout "${SS_DIR}/privkey.pem" \
        -out    "${SS_DIR}/fullchain.pem" \
        -days   3650 \
        -subj   "/CN=${DOMAIN}" \
        >> "$LOG" 2>&1 || { _fail "สร้าง self-signed cert ไม่ได้"; return 1; }

    # สร้าง symlink ในตำแหน่งที่ certbot ใช้ เพื่อให้ Nginx config ไม่ต้องแก้
    mkdir -p "/etc/letsencrypt/live/${DOMAIN}"
    ln -sf "${SS_DIR}/fullchain.pem" "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem"
    ln -sf "${SS_DIR}/privkey.pem"   "/etc/letsencrypt/live/${DOMAIN}/privkey.pem"

    _ok "Self-signed cert สร้างแล้ว — Nginx จะ start ได้"
    WARN_STEPS+=("ใช้ self-signed cert — รัน certbot เองหลัง DDNS อัพเดต: certbot certonly --standalone -d ${DOMAIN} && systemctl reload nginx")
}

# ── Step 8: Nginx config ─────────────────────────────────────────
do_nginx_config() {
    _step "Nginx reverse proxy (port 80 + 443 → Xray)"

    local CERT_PATH="/etc/letsencrypt/live/${DOMAIN}/fullchain.pem"
    local KEY_PATH="/etc/letsencrypt/live/${DOMAIN}/privkey.pem"
    local NGINX_SITE="/etc/nginx/sites-available/vmess"

    rm -f /etc/nginx/sites-enabled/default
    # ลบ conf.d ที่อาจสร้างไว้จาก run ก่อนหน้า
    rm -f /etc/nginx/conf.d/vmess-tune.conf

    # patch nginx.conf http block — เพิ่มเฉพาะที่ขาด
    if ! grep -q "keepalive_requests" /etc/nginx/nginx.conf 2>/dev/null; then
        sed -i '/keepalive_timeout/a\\tkeepalive_requests 2000;' /etc/nginx/nginx.conf
    fi
    sed -i 's/^\s*gzip\s\+on\s*;/\tgzip off;/'   /etc/nginx/nginx.conf 2>/dev/null || true
    grep -q "server_tokens" /etc/nginx/nginx.conf || \
        sed -i '/keepalive_timeout/a\\tserver_tokens off;' /etc/nginx/nginx.conf

    cat > "$NGINX_SITE" << NGINXEOF
upstream xray_ws {
    server 127.0.0.1:${XRAY_INTERNAL_PORT};
    keepalive 4;
}

server {
    listen 80 fastopen=256;
    server_name ${DOMAIN};

    location / {
        return 301 https://\$host\$request_uri;
    }

    location ${WS_PATH} {
        proxy_pass              http://xray_ws;
        proxy_http_version      1.1;
        proxy_set_header        Upgrade \$http_upgrade;
        proxy_set_header        Connection "upgrade";
        proxy_set_header        Host \$host;
        proxy_set_header        X-Real-IP \$remote_addr;
        proxy_set_header        X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_buffering         off;
        proxy_request_buffering off;
        proxy_read_timeout      86400s;
        proxy_send_timeout      86400s;
        proxy_connect_timeout   10s;
        tcp_nodelay             on;
    }
}

server {
    listen 443 ssl fastopen=256;
    server_name ${DOMAIN};

    ssl_certificate         ${CERT_PATH};
    ssl_certificate_key     ${KEY_PATH};
    ssl_protocols           TLSv1.2 TLSv1.3;
    ssl_ciphers             TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache       shared:SSL:10m;
    ssl_session_timeout     4h;
    ssl_session_tickets     on;
    ssl_stapling            on;
    ssl_stapling_verify     on;
    resolver                1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout        5s;

    add_header Strict-Transport-Security "max-age=31536000" always;

    location / {
        return 200 'OK';
        add_header Content-Type text/plain;
    }

    location ${WS_PATH} {
        proxy_pass              http://xray_ws;
        proxy_http_version      1.1;
        proxy_set_header        Upgrade \$http_upgrade;
        proxy_set_header        Connection "upgrade";
        proxy_set_header        Host \$host;
        proxy_set_header        X-Real-IP \$remote_addr;
        proxy_set_header        X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header        X-Forwarded-Proto https;
        proxy_buffering         off;
        proxy_request_buffering off;
        proxy_read_timeout      86400s;
        proxy_send_timeout      86400s;
        proxy_connect_timeout   10s;
        tcp_nodelay             on;
    }
}
NGINXEOF

    ln -sf "$NGINX_SITE" /etc/nginx/sites-enabled/vmess

    if nginx -t 2>&1 | tee -a "$LOG" | grep -E "error|warn" | sed 's/^/    /'; then
        :
    fi

    if nginx -t >> "$LOG" 2>&1; then
        _ok "Nginx config valid"
    else
        _fail "Nginx config test ล้มเหลว"
        nginx -t 2>&1 | tail -5 | sed 's/^/    /'
        return 1
    fi
}

# ── Step 9: Xray config ──────────────────────────────────────────
do_xray_config() {
    _step "Xray VMESS WS inbound config (2 users)"

    local XCONF_DIR="/usr/local/etc/xray"
    local XUI_DB="/etc/x-ui/x-ui.db"
    mkdir -p "$XCONF_DIR" /var/log/xray

    UUID1=$(cat /proc/sys/kernel/random/uuid)
    UUID2=$(cat /proc/sys/kernel/random/uuid)

    # เขียน template ไว้เสมอ — ใช้ fallback หรือ reference
    cat > "${XCONF_DIR}/config.json.template" << XRAYEOF
{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error":  "/var/log/xray/error.log"
  },
  "inbounds": [{
    "tag":      "vmess-ws",
    "port":     ${XRAY_INTERNAL_PORT},
    "listen":   "127.0.0.1",
    "protocol": "vmess",
    "settings": {
      "clients": [
        { "id": "${UUID1}", "alterId": 0, "email": "user1@ais.th", "level": 0 },
        { "id": "${UUID2}", "alterId": 0, "email": "user2@ais.th", "level": 0 }
      ],
      "disableInsecureEncryption": true
    },
    "streamSettings": {
      "network": "ws",
      "wsSettings": {
        "path": "${WS_PATH}",
        "headers": { "Host": "${DOMAIN}" }
      },
      "sockopt": {
        "tcpKeepAliveInterval": 30,
        "tcpKeepAliveIdle":     60
      }
    },
    "sniffing": {
      "enabled":      true,
      "destOverride": ["http", "tls"],
      "routeOnly":    false
    }
  }],
  "outbounds": [
    { "tag": "direct", "protocol": "freedom", "settings": { "domainStrategy": "UseIPv4" } },
    { "tag": "block",  "protocol": "blackhole", "settings": {} }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "ip": ["geoip:private"], "outboundTag": "block" },
      { "type": "field", "outboundTag": "direct" }
    ]
  },
  "dns": { "servers": ["1.1.1.1", "8.8.8.8"] },
  "policy": {
    "levels": {
      "0": { "handshakeSec": 4, "connIdle": 300, "uplinkOnly": 5, "downlinkOnly": 30, "bufferSize": 4 }
    }
  }
}
XRAYEOF

    local INJECT_OK=false

    # ── ลอง inject เข้า 3X-UI DB ───────────────────────────────
    if [[ -f "$XUI_DB" ]] && command -v sqlite3 &>/dev/null; then
        _info "Injecting inbound เข้า 3X-UI database..."

        # ตรวจ schema จริงก่อน — version ต่างกัน column ต่างกัน
        local HAS_ALLOCATE HAS_ENABLE
        HAS_ALLOCATE=$(sqlite3 "$XUI_DB" \
            "SELECT COUNT(*) FROM pragma_table_info('inbounds') WHERE name='allocate';" 2>/dev/null) || HAS_ALLOCATE=0
        HAS_ENABLE=$(sqlite3 "$XUI_DB" \
            "SELECT COUNT(*) FROM pragma_table_info('inbounds') WHERE name='enable';" 2>/dev/null) || HAS_ENABLE=0

        local IB="{\"clients\":[{\"id\":\"${UUID1}\",\"alterId\":0,\"email\":\"user1@ais.th\",\"level\":0},{\"id\":\"${UUID2}\",\"alterId\":0,\"email\":\"user2@ais.th\",\"level\":0}],\"disableInsecureEncryption\":true}"
        local SS="{\"network\":\"ws\",\"security\":\"none\",\"wsSettings\":{\"path\":\"${WS_PATH}\",\"headers\":{\"Host\":\"${DOMAIN}\"}},\"sockopt\":{\"tcpKeepAliveInterval\":30,\"tcpKeepAliveIdle\":60}}"
        local SN='{"enabled":true,"destOverride":["http","tls"],"routeOnly":false}'

        cp "$XUI_DB" "${XUI_DB}.bak.$(date +%s)"

        local SQL_RC=0
        if [[ "$HAS_ALLOCATE" -gt 0 ]]; then
            # schema เดิม (มี allocate column)
            sqlite3 "$XUI_DB" 2>>"$LOG" << SQLEOF || SQL_RC=$?
DELETE FROM inbounds WHERE port = ${XRAY_INTERNAL_PORT};
INSERT INTO inbounds (user_id, up, down, total, remark, enable, expiry_time, listen, port, protocol, settings, stream_settings, tag, sniffing, allocate)
VALUES (1, 0, 0, 0, 'vmess-ws-ais', 1, 0, '127.0.0.1', ${XRAY_INTERNAL_PORT}, 'vmess', '${IB}', '${SS}', 'vmess-ws', '${SN}', '{}');
SQLEOF
        else
            # schema ใหม่ (ไม่มี allocate)
            sqlite3 "$XUI_DB" 2>>"$LOG" << SQLEOF || SQL_RC=$?
DELETE FROM inbounds WHERE port = ${XRAY_INTERNAL_PORT};
INSERT INTO inbounds (user_id, up, down, total, remark, enable, expiry_time, listen, port, protocol, settings, stream_settings, tag, sniffing)
VALUES (1, 0, 0, 0, 'vmess-ws-ais', 1, 0, '127.0.0.1', ${XRAY_INTERNAL_PORT}, 'vmess', '${IB}', '${SS}', 'vmess-ws', '${SN}');
SQLEOF
        fi

        if [[ $SQL_RC -eq 0 ]]; then
            INJECT_OK=true
            _ok "Inbound injected เข้า 3X-UI DB สำเร็จ"
            _dim "Schema: allocate_col=${HAS_ALLOCATE}"
        else
            _warn "SQLite inject ล้มเหลว (exit ${SQL_RC}) — ดู schema จริง:"
            sqlite3 "$XUI_DB" ".schema inbounds" 2>/dev/null | sed 's/^/    /' || true
            _warn "Fallback: เขียน Xray config ตรง"
        fi
    else
        _warn "3X-UI DB ยังไม่มี หรือไม่มี sqlite3 — ใช้ config ตรง"
    fi

    # ── Fallback: เขียน config.json ตรงที่ Xray ใช้ ───────────
    # 3X-UI version ใหม่ใช้ path: /usr/local/x-ui/bin/config.json
    # และ symlink จาก /usr/local/etc/xray/config.json
    if [[ "$INJECT_OK" == "false" ]]; then
        cp "${XCONF_DIR}/config.json.template" "${XCONF_DIR}/config.json"

        # symlink ให้ x-ui binary เห็น config เดียวกัน
        local XUI_CONF="/usr/local/x-ui/bin/config.json"
        if [[ -d "/usr/local/x-ui/bin" ]]; then
            cp "${XCONF_DIR}/config.json.template" "$XUI_CONF"
            _dim "Copied config → ${XUI_CONF}"
        fi

        _warn "เขียน config ตรง — ถ้า inbound หายหลัง x-ui restart ให้รัน:"
        _warn "  bash ${SCRIPT_PATH} inject-inbound"
        WARN_STEPS+=("Xray config เขียนตรง — verify ใน panel ถ้า inbound หาย")
    fi

    _ok "Xray config ready"
    _dim "User 1 UUID: ${UUID1}"
    _dim "User 2 UUID: ${UUID2}"
}

# ── Step 10: sysctl ──────────────────────────────────────────────
do_sysctl() {
    _step "sysctl tuning — BBR + Low-Jitter Mobile"

    cat > /etc/sysctl.d/99-vmess-ais.conf << 'SYSCTLEOF'
net.core.default_qdisc          = fq
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_notsent_lowat      = 32768

net.core.rmem_default = 131072
net.core.rmem_max     = 2097152
net.core.wmem_default = 131072
net.core.wmem_max     = 2097152
net.ipv4.tcp_rmem = 4096  87380  2097152
net.ipv4.tcp_wmem = 4096  16384  2097152

net.ipv4.tcp_keepalive_time   = 60
net.ipv4.tcp_keepalive_intvl  = 10
net.ipv4.tcp_keepalive_probes = 5

net.ipv4.tcp_ecn            = 2
net.ipv4.tcp_retries1       = 3
net.ipv4.tcp_retries2       = 8
net.ipv4.tcp_syn_retries    = 4
net.ipv4.tcp_synack_retries = 3
net.ipv4.tcp_mtu_probing    = 1
net.ipv4.tcp_base_mss       = 1024
net.ipv4.tcp_fastopen       = 3
net.ipv4.tcp_tw_reuse        = 1
net.ipv4.tcp_fin_timeout     = 30

vm.swappiness             = 10
vm.dirty_ratio            = 15
vm.dirty_background_ratio = 5

net.ipv4.ip_forward              = 1
net.ipv4.conf.all.rp_filter      = 1
net.ipv4.conf.default.rp_filter  = 1
net.core.somaxconn               = 512
net.ipv4.tcp_max_syn_backlog     = 256
net.core.netdev_max_backlog      = 1000
SYSCTLEOF

    # conntrack — โหลด module ก่อนแล้ว set
    if modprobe nf_conntrack 2>/dev/null; then
        cat >> /etc/sysctl.d/99-vmess-ais.conf << 'CTEOF'
net.netfilter.nf_conntrack_max                     = 16384
net.netfilter.nf_conntrack_tcp_timeout_established = 600
net.netfilter.nf_conntrack_tcp_timeout_close_wait  = 60
net.netfilter.nf_conntrack_tcp_timeout_fin_wait    = 60
net.netfilter.nf_conntrack_tcp_timeout_time_wait   = 30
CTEOF
    fi

    local FAIL_KEYS=()
    while IFS= read -r line; do
        [[ "$line" =~ ^# || -z "$line" ]] && continue
        local key val
        key=$(echo "$line" | cut -d= -f1 | tr -d ' ')
        val=$(echo "$line" | cut -d= -f2- | tr -d ' ')
        if ! sysctl -w "${key}=${val}" >> "$LOG" 2>&1; then
            FAIL_KEYS+=("$key")
        fi
    done < /etc/sysctl.d/99-vmess-ais.conf

    if [[ ${#FAIL_KEYS[@]} -eq 0 ]]; then
        _ok "sysctl applied ทุกค่า"
    else
        _warn "sysctl ที่ apply ไม่ได้: ${FAIL_KEYS[*]}"
        _dim  "อาจ OK ถ้า kernel ไม่รองรับ"
        WARN_STEPS+=("sysctl บางค่า apply ไม่ได้: ${FAIL_KEYS[*]}")
    fi
    _dim "cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)  notsent_lowat=$(sysctl -n net.ipv4.tcp_notsent_lowat 2>/dev/null)"
}

# ── Step 11: CAKE AQM ────────────────────────────────────────────
do_cake_aqm() {
    _step "CAKE AQM — ลด bufferbloat โดยไม่ shape rate"

    local CAKE_SCRIPT="/usr/local/bin/vmess-cake.sh"

    cat > "$CAKE_SCRIPT" << 'CAKEOF'
#!/usr/bin/env bash
NIC="$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1)"
log() { logger -t vmess-cake "$*"; }
[[ -z "$NIC" ]] && { log "NIC not found"; exit 1; }

tc qdisc del dev "$NIC" root 2>/dev/null || true
tc qdisc add dev "$NIC" root cake \
    diffserv4 dual-dsthost wash ack-filter rtt 20ms noatm

log "CAKE egress active on $NIC"

if lsmod | grep -q ifb; then
    ip link add ifb0 type ifb 2>/dev/null || true
    ip link set ifb0 up 2>/dev/null || true
    tc qdisc del dev "$NIC" ingress 2>/dev/null || true
    tc qdisc add dev "$NIC" handle ffff: ingress
    tc filter add dev "$NIC" parent ffff: protocol all u32 \
        match u32 0 0 action mirred egress redirect dev ifb0
    tc qdisc del dev ifb0 root 2>/dev/null || true
    tc qdisc add dev ifb0 root cake \
        diffserv4 dual-srchost wash ingress rtt 20ms noatm
    log "CAKE ingress active on ifb0"
else
    log "IFB not available — egress only"
fi
CAKEOF
    chmod +x "$CAKE_SCRIPT"

    cat > /etc/systemd/system/vmess-cake.service << 'SVCEOF'
[Unit]
Description=CAKE AQM — VMESS AIS Mobile
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/vmess-cake.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SVCEOF

    systemctl daemon-reload
    systemctl enable vmess-cake.service

    echo ""
    echo -e "${DIM}  ── CAKE setup output ─────────────────────────────────${NC}"
    if bash "$CAKE_SCRIPT" 2>&1 | tee -a "$LOG" | sed 's/^/    /'; then
        echo -e "${DIM}  ────────────────────────────────────────────────────${NC}"
        _ok "CAKE AQM active"
        tc qdisc show dev "$NIC" 2>/dev/null | grep -q cake && \
            _ok "Verified: CAKE running on ${NIC}"
    else
        echo -e "${DIM}  ────────────────────────────────────────────────────${NC}"
        _warn "CAKE ไม่ work — fallback fq_codel"
        tc qdisc del dev "$NIC" root 2>/dev/null || true
        tc qdisc add dev "$NIC" root fq_codel 2>/dev/null && \
            _ok "fq_codel fallback active" || \
            _warn "qdisc fallback ล้มเหลวด้วย"
        WARN_STEPS+=("CAKE ไม่ work — ใช้ fq_codel แทน")
    fi
}

