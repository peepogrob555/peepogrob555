# ── Monitor ──────────────────────────────────────────────────────
do_monitor() {
    local NIC_M
    NIC_M=$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' | head -1) || true

    while true; do
